---
// Componente de transição animada - 100% da largura da tela
---

<div class="w-full bg-[#fcbe2b] overflow-hidden py-[16px]">
  <div class="marquee-track inline-flex">

    <div class="flex items-center gap-[48px] pr-[48px]">
      {Array.from({ length: 6 }).map(() => (
        <div class="flex items-center gap-[48px] shrink-0">
          <span class="font-sans text-[18px] font-medium leading-[1.5] text-[#010101] lowercase tracking-wide whitespace-nowrap">
            Se não há desafio, não há transformação!
          </span>
          <span class="text-[14px] text-[#010101]">✦</span>
        </div>
      ))}
    </div>

    <div class="flex items-center gap-[48px] pr-[48px]">
      {Array.from({ length: 6 }).map(() => (
        <div class="flex items-center gap-[48px] shrink-0">
          <span class="font-sans text-[18px] font-medium leading-[1.5] text-[#010101] lowercase tracking-wide whitespace-nowrap">
            Se não há desafio, não há transformação!
          </span>
          <span class="text-[14px] text-[#010101]">✦</span>
        </div>
      ))}
    </div>

  </div>
</div>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee-track {
    animation: marquee 50s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>