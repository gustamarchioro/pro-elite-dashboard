---
import { athletes } from '../data/athletes';
import {
  calculateMarathonsCount,
  formatNumberPtBr,
  GOAL_MARATHONS,
} from '../utils/calculations';

// Total de maratonas = soma de todos os itens de history de cada atleta
const currentMarathons = calculateMarathonsCount(athletes);
const currentMarathonsLabel = formatNumberPtBr(currentMarathons, 0, 0);

// Lógica matemática do progresso
const rawProgressPercent = (currentMarathons / GOAL_MARATHONS) * 100;
const progressPercent = Number.isFinite(rawProgressPercent)
  ? Math.max(0, Math.min(100, Number(rawProgressPercent.toFixed(3))))
  : 0;
const pctFormatted = progressPercent === 0 ? '0%' : `${formatNumberPtBr(progressPercent, 1, 1)}%`;
const scaleMarkers = [0, 200, 400, 600, 800, GOAL_MARATHONS];
---

<section class="w-full py-[48px] md:py-[80px]">
  <div class="max-w-[1280px] mx-auto px-4 md:px-8 w-full">
    <div class="flex flex-col lg:flex-row items-stretch justify-between gap-[32px]">

      <div class="flex flex-col items-start w-full shrink-0 lg:w-[592px] gap-[64px]">
        
        <div class="flex flex-col items-start w-full gap-[32px]">
          <div class="flex items-center justify-center shrink-0 px-[16px] py-[12px] rounded-full ring-1 ring-inset ring-black/10 bg-black/5">
            <span class="font-sans text-[16px] font-normal leading-[1.5] text-black/50 whitespace-nowrap">
              PRO Elite: 1000 Maratonas (2026-2030)
            </span>
          </div>

          <h1 class="font-sans text-[28px] sm:text-[32px] md:text-[40px] lg:text-[48px] font-bold leading-[1.1] text-[#010101] w-full">
            Performance se mede. Evolução se registra.
          </h1>

          <p class="font-sans font-normal text-[16px] md:text-[18px] leading-[1.5] text-[#2b2b2b] w-full self-stretch">
            Até 2030, a PRO Elite vai registrar 1000 maratonas concluídas pelo<br class="hidden md:block" />
            time. Porque se não há desafio, não há transformação. Cada atleta<br class="hidden md:block" />
            acompanha seu nome, seus números e sua posição. Aqui, esforço<br class="hidden md:block" />
            vira estatística. Disciplina vira progresso. E transformação vira dado.
          </p>
        </div>

        <div class="flex items-center gap-[16px] flex-wrap">
          <a href="#ranking"
             class="flex items-center justify-center shrink-0 px-[32px] py-[16px] rounded-full bg-[#010101] font-sans text-[18px] font-semibold leading-[1.5] text-[#fefefe] whitespace-nowrap transition-colors duration-300 hover:bg-[#fcbe2b] hover:text-[#010101]">
            Ver ranking
          </a>
          <a href="https://proeliteassessoria.com.br" target="_blank" rel="noopener noreferrer"
             class="flex items-center justify-center shrink-0 px-[32px] py-[16px] rounded-full ring-1 ring-inset ring-[#2b2b2b] font-sans text-[18px] font-normal leading-[1.5] text-[#2b2b2b] whitespace-nowrap transition-colors duration-300 hover:bg-[#fcbe2b] hover:ring-[#fcbe2b] hover:text-[#010101]">
            Entrar para o time
          </a>
          <!-- Scroll indicator -->
          <div class="scroll-arrow flex items-center ml-[8px]">
            <svg width="14" height="20" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1V17M7 17L1 11M7 17L13 11" stroke="#010101" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="flex flex-col justify-center items-center w-full shrink-0 lg:w-[592px] px-[16px] md:px-[32px] py-[40px] md:py-[60px] rounded-[16px] bg-[#fcbe2b]">
        
        <div class="flex flex-col items-center w-full max-w-[528px] gap-[48px]">
          
          <div class="flex flex-col items-center w-full gap-[16px]">
            
            <div class="flex items-start justify-between w-full font-sans text-[16px] font-bold leading-[1.5] text-[#010101] uppercase tracking-wide">
              <span>PROGRESSO DO TIME</span>
              <span>{pctFormatted}</span>
            </div>

            <div class="w-full">
              <!-- Barra de progresso -->
              <div class="relative w-full h-[39px] bg-white rounded-full shadow-[inset_0px_2px_4px_0px_rgba(0,0,0,0.15)]">
                <div class="absolute top-0 left-0 h-full bg-black rounded-full flex items-center justify-end pr-4 pl-3 min-w-fit transition-all duration-1000 ease-out"
                     style={`width: ${progressPercent}%`}>
                  <span class="font-sans text-[14px] md:text-[16px] font-semibold leading-[1.5] text-white">
                    {currentMarathonsLabel}
                  </span>
                </div>
              </div>

              <!-- Régua Numérica -->
              <div class="relative w-full h-6 mt-3 text-[10px] sm:text-xs md:text-sm font-medium font-sans text-[#010101]">
                <span class="absolute left-0">0</span>
                <span class="absolute left-[20%] -translate-x-1/2 hidden sm:inline-block">200</span>
                <span class="absolute left-[40%] -translate-x-1/2">400</span>
                <span class="absolute left-[60%] -translate-x-1/2 hidden sm:inline-block">600</span>
                <span class="absolute left-[80%] -translate-x-1/2">800</span>
                <span class="absolute right-0 flex items-center gap-1">1.000 <span class="text-[12px] md:text-[16px] font-normal leading-none" aria-hidden="true">🏆</span></span>
              </div>
            </div>
          </div>

          <div class="flex flex-col items-center gap-[32px] md:gap-[48px]">
            <p class="max-w-[496px] text-center font-sans text-[16px] md:text-[18px] font-normal leading-[1.5] text-[#010101]">
              Cada maratona concluída aproxima o time do objetivo. Cada atleta que larga, fortalece o movimento.
            </p>

            <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-[32px]">
              <span class="font-sans text-[40px] md:text-[48px] font-semibold leading-none md:leading-normal text-[#010101] whitespace-nowrap">
                {currentMarathonsLabel}
              </span>
              <span class="font-sans text-[20px] md:text-[24px] font-semibold leading-[1.5] text-[#010101] whitespace-nowrap">
                Maratonas concluídas
              </span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

</section>

<style>
  .scroll-arrow {
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-arrow { animation: none; }
  }
</style>